# Theme & colors
theme = "Catppuccin Mocha"
bold-is-bright = true
# Disable auto-generated 256-color palette (restores standard xterm colors)
# See https://github.com/ghostty-org/ghostty/discussions/10852
palette-generate = false

# Font
font-family = "Maple Mono NF CN"
font-size = 16
font-feature = calt
font-feature = liga
font-feature = cv01
font-feature = cv02
font-feature = cv07
font-feature = cv33
font-feature = cv34
font-feature = cv62
font-feature = cv64
font-feature = cv98
font-feature = ss01
font-feature = ss03
font-feature = ss05
font-feature = ss07
font-feature = ss08

# Cursor
cursor-style = bar
cursor-style-blink = false
cursor-click-to-move = true
adjust-cursor-thickness = 3
shell-integration-features = no-cursor

# Window
window-padding-x = 8
window-padding-y = 4
window-padding-balance = true
window-padding-color = extend
window-save-state = always
window-step-resize = true
scrollbar = never

# Input & clipboard
copy-on-select = clipboard
clipboard-trim-trailing-spaces = true
clipboard-paste-protection = true
focus-follows-mouse = true
mouse-hide-while-typing = true

# Keybindings
keybind = global:shift+escape=toggle_quick_terminal

# macOS
macos-option-as-alt = true
macos-hidden = always
# Render colors in Display P3 for vibrant output on macOS
window-colorspace = display-p3
# Thicker font strokes (compensates for thinner Metal rendering)
font-thicken = true
